# EcoFlow Developer API credentials
# Get these from https://developer.ecoflow.com/us/security
ACCESS_KEY=your_access_key_here
SECRET_KEY=your_secret_key_here

# Device serial number (found in EcoFlow app or via /device/list endpoint)
DEVICE_SN=your_device_serial_number

# Region: "us" or "eu"
REGION=us

# MQTT client ID - generate once, reuse forever (10 unique IDs/day limit)
# Generate with: python -c "import uuid; print(uuid.uuid4())"
MQTT_CLIENT_ID=your_persistent_client_id

# Backend settings
BACKEND_PORT=8000
FRONTEND_URL=http://localhost:5173
